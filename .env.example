# ──────────────────────────────────────────────────────
# Authentication Masterclass - Environment Variables
# ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# OpenAI API Key (required for Project 3 - RAG embeddings + LLM)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Anthropic API Key (if using Claude instead of GPT)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Tavily API Key (for web search tool)
TAVILY_API_KEY=tvly-your-key-here

# JWT Secret Key (change this in production!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string
